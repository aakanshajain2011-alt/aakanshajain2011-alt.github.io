@article{jain2025india,
  type={3. Working Papers},
  title={Trends in College Wage Premiums in India, 1987-2012},
  author={Jain, Aakansha},
  journal={},
  year={2025},
  pdf={jain_india_college.pdf},
  selected={true},
  abstract={This paper traces how the college-versus-high-school earnings gap evolved in India during the decades when tertiary enrollment expanded rapidly. Drawing on five waves of the National Sample Survey, I estimate conventional Mincer wage equations and complement them with two-part Cragg models that separate the extensive margin (labor-force participation) from the intensive margin (weekly pay, conditional on work). Repeated cross-sections are organized into synthetic birth cohorts to track wage premiums over time. The college premium rose throughout the sample period despite a near-tripling of tertiary enrollment, and rose unevenly across cohorts: older cohorts continue to command rising premiums while the youngest has begun to flatten.}
}

@article{andrade2025alumni,
  type={3. Working Papers},
  title={An Overview of the 2024 Iowa State University Alumni Survey},
  author={Andrade, A. and Eyles, J. and Jain, Aakansha and Kimle, K. and Orazem, Peter F. and Unal, R.},
  journal={ISU Department of Economics Working Paper 25007},
  year={2025},
  html={https://econpapers.repec.org/paper/isugenstf/202509021854400000.htm},
  abstract={Documents the design, sample construction, and descriptive findings of the 2024 Iowa State University alumni survey, a follow-up to the 2008 survey (Jolly, Yu, and Orazem 2009). Covers cohorts graduating from 1982 to 2023, with over 5,000 usable Bachelor's-degree responses. Reports patterns of entrepreneurship, employment, education, and geographic mobility across 41 years of ISU graduates.}
}

@article{jain_broadband,
  type={4. Works in Progress},
  title={Does Broadband Close the Rural Education Gap?},
  author={Jain, Aakansha and Winters, John V.},
  year={2026},
  abstract={This project examines whether broadband expansion raises college enrollment and slows out-migration among rural-born cohorts, and whether these effects are larger in education deserts. Uses the staggered rollout of the FCC Connect America Fund (CAF) Phase II as a source of exogenous variation in rural broadband access. Estimation requires restricted Census data accessible through the FSRDC at ISU under Project 3044 (access expected June 2026).}
}

