@article{jain_entrepreneurship,
  type={4. Works in Progress},
  title={Firm Entry and Serial Entrepreneurship Among ISU Alumni},
  author={Jain, Aakansha and Lin, Daniel and Orazem, Peter F.},
  year={2026},
  abstract={Examines how local labor market conditions at graduation shape the timing of entrepreneurial entry among ISU alumni, using the 2008 and 2024 waves of the ISU alumni survey. The Iowa unemployment rate at graduation has a significant and persistent negative effect on business entry peaking in years 10-14 after graduation; the U.S. unemployment rate has no analogous effect, consistent with local labor market conditions delaying entrepreneurial entry.}
}

