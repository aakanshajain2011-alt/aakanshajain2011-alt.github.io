@article{jain2026h2a,
  abbr={JMP},
  type={1. Job Market Paper},
  title={The Rise of H-2A: Causal Evidence on Guestworker Substitution for Settled Farm Labor},
  author={Jain, Aakansha},
  journal={},
  year={2026},
  pdf={jain_h2a_jmp.pdf},
  selected={true},
  abstract={The U.S. settled non-citizen agricultural workforce has declined substantially since the mid-2000s, while H-2A temporary guestworker certifications have grown more than fivefold over the same period. This paper asks whether the rise of H-2A reflects a causal response to the decline in settled farm labor, and estimates the substitution elasticity between the two workforces. Using a panel of settled non-citizen agricultural labor (PANCAL) constructed from the American Community Survey across 740 U.S. commuting zones over 2008-2024, I instrument for changes in the settled workforce using a shift-share design that interacts baseline 2000 non-citizen agricultural labor shares with two sources of national variation in immigration enforcement: Border Patrol budget shocks and agricultural-season border encounters. IV estimates imply that each settled non-citizen agricultural worker lost is replaced by 1.7 to 2.5 H-2A certifications (Hansen J p = 0.128). The findings show that the expansion of H-2A has been driven by the contraction of the settled farm workforce, reshaping the composition of U.S. agricultural labor and raising design questions for guestworker policy.}
}

